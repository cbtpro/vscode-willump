{
  "name": "willump",
  "displayName": "willump",
  "description": "威朗普",
  "version": "0.0.2",
  "publisher": "cbtpro",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:willump.featuresView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "willump",
          "title": "Willump",
          "icon": "assets/activity-bar.svg"
        }
      ]
    },
    "views": {
      "willump": [
        {
          "id": "willump.featuresView",
          "name": "功能入口"
        }
      ]
    },
    "commands": [
      {
        "command": "willump.checkPort",
        "title": "Willump: 检查端口占用情况"
      },
      {
        "command": "willump.killPort",
        "title": "Willump: 终止占用端口的进程"
      },
      {
        "command": "willump.listPorts",
        "title": "Willump: 查看所有端口占用情况"
      },
      {
        "command": "willump.viewPorts",
        "title": "Willump: 查看端口占用"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cbtpro/vscode-willump.git"
  },
  "bugs": {
    "url": "https://github.com/cbtpro/vscode-willump/issues"
  },
  "author": {
    "name": "cbtpro",
    "url": "https://github.com/cbtpro"
  },
  "scripts": {
    "preinstall": "npm install -g vsce",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "compile": "npm run compile:webview && tsc -p ./",
    "compile:extension": "tsc -p ./",
    "compile:webview": "vite build --config vite.webview.config.ts",
    "watch": "tsc -watch -p ./",
    "watch:webview": "vite build --watch --config vite.webview.config.ts",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "vue": "^3.5.34"
  }
}
